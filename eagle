local PLACE_ID = 129118369937980

local function getServerList(cursor)
    local url = "https://games.roblox.com/v1/games/" .. PLACE_ID
        .. "/servers/Public?sortOrder=Asc&limit=100"
    if cursor and cursor ~= "" then
        url = url .. "&cursor=" .. cursor
    end
    local ok, res = pcall(function()
        return HttpService:JSONDecode(game:HttpGet(url))
    end)
    if ok and res then return res end
    return nil
end

local function hopToEmptyServer()
    if IsHopping then return end
    IsHopping = true
    AutoFarmActive = false

    WindUI:Notify({ Title = "Forky", Content = "Scanning for empty servers...", Duration = 4 })

    local currentJobId = game.JobId
    local bestServer   = nil
    local minPlayers   = math.huge
    local cursor       = nil
    local attempts     = 0

    repeat
        local data = getServerList(cursor)
        if not data or not data.data then break end

        for _, server in ipairs(data.data) do
            if server.id == currentJobId then continue end
            if server.playing >= server.maxPlayers then continue end
            if server.playing < minPlayers then
                minPlayers = server.playing
                bestServer = server
            end
            if minPlayers <= 1 then break end
        end

        cursor   = data.nextPageCursor
        attempts = attempts + 1
        task.wait(0.5)
    until not cursor or cursor == "" or minPlayers <= 1 or attempts >= 5

    if bestServer then
        WindUI:Notify({ Title = "Forky", Content = "Teleporting to server with " .. minPlayers .. " player(s).", Duration = 4 })
        task.wait(1)
        pcall(function()
            TeleportService:TeleportToPlaceInstance(PLACE_ID, bestServer.id, Player)
        end)
    else
        WindUI:Notify({ Title = "Forky", Content = "No available servers found. Try again.", Duration = 5 })
        IsHopping = false
    end
end


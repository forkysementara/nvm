local function runAuth()
    local Players = game:GetService("Players")
    local TweenService = game:GetService("TweenService")
    local Lighting = game:GetService("Lighting")
    local RunService = game:GetService("RunService")
    local CoreGui = game:GetService("CoreGui")

    -- 1. Setup UI & Animation
    local gui = Instance.new("ScreenGui", CoreGui)
    gui.Name = "ForkyAuthUI"
    gui.IgnoreGuiInset = true
    
    local blur = Instance.new("BlurEffect", Lighting)
    blur.Size = 0

    local main = Instance.new("CanvasGroup", gui)
    main.AnchorPoint = Vector2.new(0.5, 0.5)
    main.Position = UDim2.new(0.5, 0, 0.5, 0)
    main.Size = UDim2.new(0, 350, 0, 180)
    main.BackgroundColor3 = Color3.fromRGB(10, 10, 12)
    main.GroupTransparency = 1
    Instance.new("UICorner", main).CornerRadius = UDim.new(0, 24)
    
    local status = Instance.new("TextLabel", main)
    status.Position = UDim2.new(0, 0, 0, 130)
    status.Size = UDim2.new(1, 0, 0, 20)
    status.BackgroundTransparency = 1
    status.Text = "Initializing..."
    status.TextColor3 = Color3.fromRGB(150, 150, 165)
    status.Font = Enum.Font.GothamMedium
    status.TextSize = 13

    -- Orbital Rings
    local orbitCont = Instance.new("Frame", main)
    orbitCont.Position = UDim2.new(0.5, 0, 0, 55)
    orbitCont.BackgroundTransparency = 1

    local function createRing(size, speed, color)
        local r = Instance.new("Frame", orbitCont)
        r.AnchorPoint = Vector2.new(0.5, 0.5)
        r.Size = UDim2.new(0, size, 0, size)
        r.BackgroundTransparency = 1
        local st = Instance.new("UIStroke", r)
        st.Color = color
        st.Transparency = 0.5
        Instance.new("UICorner", r).CornerRadius = UDim.new(1,0)
        task.spawn(function()
            local a = 0
            while r and r.Parent do
                a = a + speed
                r.Rotation = a
                RunService.RenderStepped:Wait()
            end
        end)
    end
    createRing(75, 2.5, Color3.fromRGB(0, 225, 255))
    createRing(95, -1.8, Color3.fromRGB(0, 100, 255))

    -- 2. Start Entrance
    TweenService:Create(main, TweenInfo.new(0.6), {GroupTransparency = 0}):Play()
    TweenService:Create(blur, TweenInfo.new(0.6), {Size = 20}):Play()
    task.wait(0.8)

    -- 3. Logic Auth Junkie
    local key = getgenv().SCRIPT_KEY
    if not key or key == "" then
        status.Text = "Error: Key Missing!"
        status.TextColor3 = Color3.fromRGB(255, 59, 48)
        task.wait(2)
        handleKick("No license key provided.")
        return false
    end

    status.Text = "Verifying License..."
    local result = Junkie.check_key(key)

    if result and result.valid then
        status.Text = "Access Granted!"
        status.TextColor3 = Color3.fromRGB(52, 199, 89)
        task.wait(1)
        
        -- Closing Anim
        TweenService:Create(main, TweenInfo.new(0.5), {GroupTransparency = 1}):Play()
        TweenService:Create(blur, TweenInfo.new(0.5), {Size = 0}):Play()
        task.wait(0.5)
        gui:Destroy()
        blur:Destroy()
        return true
    else
        local raw = result and result.message or "UNKNOWN"
        status.Text = "Error: " .. raw
        status.TextColor3 = Color3.fromRGB(255, 59, 48)
        task.wait(2)
        
        if raw:find("invalid") then handleKick("Key Invalid")
        elseif raw:find("expire") then handleKick("Key Expired")
        elseif raw:find("hwid") then handleKick("HWID Mismatch")
        else handleKick("Error: "..raw) end
        
        return false
    end
end


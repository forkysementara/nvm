local FEED_ACTION_TEXTS = { "Feed Horse", "Deliver Package", "feed horse", "deliver package" }

local function findFeedPrompt(target)
    if not target then return nil end
    for _, obj in ipairs(target:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then
            local act = obj.ActionText:lower()
            for _, keyword in ipairs(FEED_ACTION_TEXTS) do
                if act:find(keyword:lower(), 1, true) then return obj end
            end
        end
    end
    for _, obj in ipairs(target:GetDescendants()) do
        if obj:IsA("ProximityPrompt") then return obj end
    end
    if target:IsA("BasePart") then
        local p = target:FindFirstChildOfClass("ProximityPrompt")
        if p then return p end
    end
    return nil
end

local function getTargetPosition(target)
    if not target then return nil end
    if target:IsA("BasePart") then
        return target.Position
    elseif target:IsA("Model") then
        local prim = target.PrimaryPart
        if prim then return prim.Position end
        local bp = target:FindFirstChildWhichIsA("BasePart", true)
        if bp then return bp.Position end
    end
    return nil
end


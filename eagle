local function hasWheatInInventory()
    -- Cek backpack player
    local backpack = Player:FindFirstChild("Backpack")
    if backpack then
        for _, item in ipairs(backpack:GetChildren()) do
            local name = item.Name:lower()
            if name:find("wheat") or name:find("hay") then
                return true
            end
        end
    end

    -- Cek karakter (equipped tool)
    local char = Player.Character
    if char then
        for _, item in ipairs(char:GetChildren()) do
            if item:IsA("Tool") then
                local name = item.Name:lower()
                if name:find("wheat") or name:find("hay") then
                    return true
                end
            end
        end
    end

    -- Cek via leaderstats / attribute jika game pakai system lain
    local data = Player:FindFirstChild("PlayerData") or Player:FindFirstChild("Data")
    if data then
        local inv = data:FindFirstChild("Inventory") or data:FindFirstChild("Items")
        if inv then
            for _, item in ipairs(inv:GetChildren()) do
                local name = item.Name:lower()
                if name:find("wheat") or name:find("hay") then
                    return (item.Value or 0) > 0
                end
            end
        end
    end

    return false
end


local currentDeliveryTarget = nil
local deliveryDone          = false

local function listenDeliveryEvent()
    if not deliveryEvent then return end

    deliveryEvent.OnClientEvent:Connect(function(evtType, ...)
        if evtType == "START" then
            local deliveryName = ...
            if not deliveryName then return end

            local activeFolder = workspace:FindFirstChild("ActiveDeliveries")
            local target       = nil
            local elapsed      = 0
            while elapsed < 5 do
                activeFolder = workspace:FindFirstChild("ActiveDeliveries")
                if activeFolder then
                    target = activeFolder:FindFirstChild(deliveryName)
                    if target then break end
                end
                task.wait(0.2)
                elapsed = elapsed + 0.2
            end

            if target then
                currentDeliveryTarget = target
                deliveryDone          = false
            end

        elseif evtType == "STOP" then
            deliveryDone          = true
            currentDeliveryTarget = nil

        elseif evtType == "CANCEL" then
            deliveryDone          = true
            currentDeliveryTarget = nil
        end
    end)
end


-- SECTION 13 : ONE FARM CYCLE
-- ══════════════════════════════════════════════════════════════
local function doOneCycle()
    -- ✅ CEK INVENTORY DULU
    local alreadyHasWheat = hasWheatInInventory()

    if alreadyHasWheat then
        -- Punya wheat tapi belum deliver → skip grab, langsung deliver
        WindUI:Notify({ Title = "AutoFarm", Content = "Wheat detected! Skipping grab, delivering...", Duration = 3 })
    else
        -- Inventory kosong → grab wheat dulu
        local hayPrompt = getHayPrompt()
        if not hayPrompt then
            WindUI:Notify({ Title = "AutoFarm", Content = "Hay NPC prompt not found. Retrying...", Duration = 4 })
            return false
        end

        local npcPart = hayPrompt.Parent
        local npcPos  = nil
        if npcPart:IsA("BasePart") then
            npcPos = npcPart.Position
        elseif npcPart:IsA("Attachment") then
            npcPos = npcPart.WorldPosition
        else
            local bp = npcPart:FindFirstChildWhichIsA("BasePart", true)
            npcPos = bp and bp.Position or Vector3.new(0, 5, 0)
        end

        teleportTo(npcPos)

        currentDeliveryTarget = nil
        deliveryDone          = false

        hayPrompt.MaxActivationDistance = 999999
        firePrompt(hayPrompt, 1.5)
        task.wait(FarmDelay + 0.5)

        -- ✅ Tunggu wheat masuk inventory (max 5 detik)
        local waitWheat = 0
        while not hasWheatInInventory() and waitWheat < 5 do
            task.wait(0.3)
            waitWheat = waitWheat + 0.3
        end

        -- Kalau setelah grab masih ga ada wheat, retry cycle
        if not hasWheatInInventory() then
            WindUI:Notify({ Title = "AutoFarm", Content = "Wheat not received, retrying grab...", Duration = 3 })
            return true -- kembali ke loop, coba lagi
        end
    end

    -- ✅ Tunggu delivery target muncul (dari event)
    local waitElapsed = 0
    while not currentDeliveryTarget and waitElapsed < 6 do
        task.wait(0.2)
        waitElapsed = waitElapsed + 0.2
    end

    if not currentDeliveryTarget then
        WindUI:Notify({ Title = "AutoFarm", Content = "No delivery target found, retrying...", Duration = 3 })
        return true
    end

    local targetPos = getTargetPosition(currentDeliveryTarget)
    if not targetPos then return true end

    teleportTo(targetPos)
    task.wait(FarmDelay)

    local feedPrompt = findFeedPrompt(currentDeliveryTarget)
    if feedPrompt then
        feedPrompt.MaxActivationDistance = 999999
        firePrompt(feedPrompt, 1.5)
    else
        for _, obj in ipairs(workspace:GetDescendants()) do
            if obj:IsA("ProximityPrompt") then
                local act = obj.ActionText:lower()
                if act:find("feed", 1, true) or act:find("deliver", 1, true) then
                    local part = obj.Parent
                    local pos  = nil
                    if part:IsA("BasePart") then pos = part.Position
                    elseif part:IsA("Attachment") then pos = part.WorldPosition end
                    if pos and (pos - targetPos).Magnitude < 20 then
                        obj.MaxActivationDistance = 999999
                        firePrompt(obj, 1.5)
                        break
                    end
                end
            end
        end
    end

    -- ✅ Tunggu delivery selesai
    local doneElapsed = 0
    while not deliveryDone and doneElapsed < 8 do
        task.wait(0.2)
        doneElapsed = doneElapsed + 0.2
    end

    -- Reset setelah deliver selesai
    deliveryDone = false
    currentDeliveryTarget = nil

    return true
end

-- ══════════════════════════════════════════════════════════════
-- SECTION 14 : MAIN FARM LOOP
-- ══════════════════════════════════════════════════════════════
local function startFarmLoop()
    local ranchPart = workspace:FindFirstChild("TeleportPoints")
        and workspace.TeleportPoints:FindFirstChild("TeleportRanch")
    if ranchPart then
        local pos = nil
        if ranchPart:IsA("BasePart") then
            pos = ranchPart.Position
        elseif ranchPart:IsA("Model") then
            local prim = ranchPart.PrimaryPart
            pos = prim and prim.Position
                or (ranchPart:FindFirstChildWhichIsA("BasePart", true) and
                    ranchPart:FindFirstChildWhichIsA("BasePart", true).Position)
        end
        if pos then
            teleportTo(pos)
            task.wait(1)
        end
    end

    while AutoFarmActive do
        local ok = pcall(doOneCycle)
        if not ok then task.wait(2) end
        if AutoFarmActive then task.wait(FarmDelay) end
    end
    WindUI:Notify({ Title = "Forky", Content = "AutoFarm stopped.", Duration = 3 })
end

